# TradeIQ — API Keys & Config
# העתק קובץ זה ל-.env ומלא את המפתחות

# ── Trading Data ──────────────────────────────────────────────
# Marketaux — חדשות עם ניתוח סנטימנט מובנה
# הרשמה חינם: https://www.marketaux.com/
MARKETAUX_API_KEY=

# Finnhub — נתוני שוק + חדשות
# הרשמה חינם: https://finnhub.io/
FINNHUB_API_KEY=

# Reddit — סנטימנט מ-r/wallstreetbets, r/stocks וכו'
# צור אפליקציה חינם: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TradeIQ/1.0

# Brave Search MCP — חיפוש חדשות
# הרשמה חינם: https://brave.com/search/api/
BRAVE_API_KEY=

# ── Telegram — דוחות יומיים ──────────────────────────────────
# צור bot: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# קבל CHAT_ID: שלח הודעה ל-bot שלך ואז פתח:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ── Stripe — תשלומים ─────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# צור Products ב-Stripe Dashboard ← Pricing, העתק את ה-price IDs:
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# ── App Config ────────────────────────────────────────────────
FLASK_SECRET=change-me-to-random-string
# כתובת ה-Streamlit app (ב-Railway: https://your-app.railway.app)
STREAMLIT_URL=http://localhost:8501
